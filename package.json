{
  "name": "validex",
  "type": "module",
  "version": "1.0.0-alpha.0",
  "packageManager": "pnpm@9.15.0",
  "description": "Type-safe validation rules built on Zod",
  "license": "MIT",
  "homepage": "https://github.com/chiptoma/validex#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/chiptoma/validex.git"
  },
  "bugs": {
    "url": "https://github.com/chiptoma/validex/issues"
  },
  "keywords": [
    "zod",
    "validation",
    "zod4",
    "email",
    "phone",
    "typescript",
    "i18n",
    "nuxt",
    "fastify",
    "tree-shakeable"
  ],
  "sideEffects": ["./src/augmentation/index.ts", "./src/augmentation/types.ts", "./src/augmentation/methods.ts", "./dist/index.js", "./dist/index.mjs", "./dist/index.cjs"],
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./rules": {
      "import": {
        "types": "./dist/rules/index.d.ts",
        "default": "./dist/rules/index.js"
      },
      "require": {
        "types": "./dist/rules/index.d.cts",
        "default": "./dist/rules/index.cjs"
      }
    },
    "./checks": {
      "import": {
        "types": "./dist/checks/index.d.ts",
        "default": "./dist/checks/index.js"
      },
      "require": {
        "types": "./dist/checks/index.d.cts",
        "default": "./dist/checks/index.cjs"
      }
    },
    "./utilities": {
      "import": {
        "types": "./dist/utilities/index.d.ts",
        "default": "./dist/utilities/index.js"
      },
      "require": {
        "types": "./dist/utilities/index.d.cts",
        "default": "./dist/utilities/index.cjs"
      }
    },
    "./nuxt": {
      "import": {
        "types": "./dist/adapters/nuxt/index.d.ts",
        "default": "./dist/adapters/nuxt/index.js"
      },
      "require": {
        "types": "./dist/adapters/nuxt/index.d.cts",
        "default": "./dist/adapters/nuxt/index.cjs"
      }
    },
    "./fastify": {
      "import": {
        "types": "./dist/adapters/fastify/index.d.ts",
        "default": "./dist/adapters/fastify/index.js"
      },
      "require": {
        "types": "./dist/adapters/fastify/index.d.cts",
        "default": "./dist/adapters/fastify/index.cjs"
      }
    },
    "./locales/en": {
      "import": {
        "types": "./dist/locales/en.d.ts",
        "default": "./dist/locales/en.js"
      },
      "require": {
        "types": "./dist/locales/en.d.cts",
        "default": "./dist/locales/en.cjs"
      }
    }
  },
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "validex": "./dist/cli/index.js"
  },
  "files": [
    "CHANGELOG.md",
    "LICENSE",
    "README.md",
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "dev": "tsup --watch & vitest",
    "build": "tsup",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:checks": "vitest run tests/checks",
    "test:rules": "vitest run tests/rules",
    "test:integration": "vitest run tests/integration",
    "test:properties": "vitest run tests/properties",
    "test:adapters": "vitest run tests/adapters",
    "test:fuzz": "vitest run tests/fuzz",
    "test:loaders": "vitest run tests/loaders",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "check:full": "pnpm check && pnpm test:coverage && pnpm build && publint && attw --pack --ignore-rules no-resolution unexpected-module-syntax && pnpm knip && pnpm size",
    "knip": "knip",
    "size": "size-limit",
    "size:detail": "node --experimental-strip-types scripts/measureBundle.ts",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s",
    "release": "bumpp && pnpm changelog && git add CHANGELOG.md && git commit -m 'chore: changelog' && git push --follow-tags && pnpm publish",
    "prepublishOnly": "pnpm check:full",
    "prepare": "simple-git-hooks"
  },
  "peerDependencies": {
    "@nuxt/kit": "^4.4.2",
    "fastify-plugin": "^5.1.0",
    "zod": "^3.25.0 || ^4.0.0"
  },
  "peerDependenciesMeta": {
    "@nuxt/kit": {
      "optional": true
    },
    "fastify": {
      "optional": true
    },
    "fastify-plugin": {
      "optional": true
    },
    "nuxt": {
      "optional": true
    }
  },
  "dependencies": {
    "disposable-email-domains": "^1.0.62",
    "libphonenumber-js": "^1.12.41",
    "postcode-validator": "^3.10.15"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@arethetypeswrong/cli": "^0.18.2",
    "@emnapi/core": "^1.9.1",
    "@emnapi/runtime": "^1.9.1",
    "@faker-js/faker": "^10.4.0",
    "@nuxt/kit": "^4.4.2",
    "@nuxt/test-utils": "^4.0.0",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "bumpp": "^11.0.1",
    "conventional-changelog-cli": "^5.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.1.0",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-vitest": "^0.5.4",
    "fast-check": "^4.6.0",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "knip": "^6.1.0",
    "lint-staged": "^16.4.0",
    "nuxt": "^4.4.2",
    "publint": "^0.3.18",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^12.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@typescript-eslint/rule-tester"
      ],
      "allowAny": [
        "eslint"
      ]
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm typecheck",
    "commit-msg": "node --input-type=module -e \"import {readFileSync} from 'fs'; const msg = readFileSync(process.argv[1], 'utf8').trim(); if (!/^(feat|fix|docs|refactor|test|chore|perf|ci|build|style|revert|security)(\\\\(.+\\\\))?!?:.+/.test(msg)) { console.error('Invalid commit message. Use conventional commits: feat|fix|docs|refactor|test|chore: message'); process.exit(1); }\" \"$1\""
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ]
  }
}
