{
  "name": "validex-monorepo",
  "type": "module",
  "version": "1.0.0-alpha.0",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "description": "Type-safe validation rules built on Zod — monorepo workspace",
  "license": "MIT",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "test:coverage": "pnpm -r test:coverage",
    "test:smoke": "bash scripts/smokeTest.sh",
    "check": "pnpm lint && pnpm typecheck && pnpm test",
    "check:full": "pnpm check && pnpm -r build && pnpm -r exec publint && pnpm knip && pnpm size",
    "knip": "knip",
    "size": "size-limit",
    "size:detail": "node --experimental-strip-types packages/core/scripts/measureBundle.ts",
    "changelog": "conventional-changelog -p conventionalcommits -i CHANGELOG.md -s",
    "release": "bumpp && pnpm changelog && git add CHANGELOG.md && git commit -m 'chore: changelog' && git push --follow-tags && pnpm -r publish --no-git-checks",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.7.3",
    "@arethetypeswrong/cli": "^0.18.2",
    "@emnapi/core": "^1.9.1",
    "@emnapi/runtime": "^1.9.1",
    "@faker-js/faker": "^10.4.0",
    "@nuxt/kit": "^4.4.2",
    "@nuxt/test-utils": "^4.0.0",
    "@size-limit/preset-small-lib": "^12.0.1",
    "@types/node": "^25.5.0",
    "@vitest/coverage-v8": "^4.1.2",
    "bumpp": "^11.0.1",
    "conventional-changelog-cli": "^5.0.0",
    "conventional-changelog-conventionalcommits": "^9.3.1",
    "eslint": "^10.1.0",
    "eslint-plugin-regexp": "^3.1.0",
    "eslint-plugin-sonarjs": "^4.0.2",
    "eslint-plugin-vitest": "^0.5.4",
    "fast-check": "^4.6.0",
    "fastify": "^5.8.4",
    "fastify-plugin": "^5.1.0",
    "knip": "^6.1.0",
    "lint-staged": "^16.4.0",
    "nuxt": "^4.4.2",
    "publint": "^0.3.18",
    "simple-git-hooks": "^2.13.1",
    "size-limit": "^12.0.1",
    "tsup": "^8.5.1",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2",
    "zod": "^4.3.6"
  },
  "pnpm": {
    "peerDependencyRules": {
      "ignoreMissing": [
        "@typescript-eslint/rule-tester"
      ],
      "allowAny": [
        "eslint"
      ]
    }
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint-staged && pnpm typecheck",
    "commit-msg": "node --input-type=module -e \"import {readFileSync} from 'fs'; const msg = readFileSync(process.argv[1], 'utf8').trim(); if (!/^(feat|fix|docs|refactor|test|chore|perf|ci|build|style|revert|security)(\\\\(.+\\\\))?!?:.+/.test(msg)) { console.error('Invalid commit message. Use conventional commits: feat|fix|docs|refactor|test|chore: message'); process.exit(1); }\" \"$1\""
  },
  "lint-staged": {
    "*.ts": [
      "eslint --fix"
    ]
  }
}
